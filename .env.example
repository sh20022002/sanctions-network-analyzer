# ════════════════════════════════════════════════════════════
# SECRETS - NEVER COMMIT THIS FILE
# Copy to .env and fill in your real credentials
# ════════════════════════════════════════════════════════════

# OpenCorporates API Token
# Get free API key at: https://opencorporates.com/users/sign_up
# Free tier allows limited queries; paid tiers available
OPENCORPORATES_API_TOKEN=your_api_token_here

# ════════════════════════════════════════════════════════════
# Neo4j Database Configuration
# ════════════════════════════════════════════════════════════

# Neo4j connection details
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j

# IMPORTANT: Use a strong password (min 12 characters, mix of alphanumeric + special chars)
# Example strong password: Sanctions!2024#Secure
# NEVER use: password, neo4j, 123456, admin, etc.
NEO4J_PASSWORD=your_secure_password_min_12_chars

# ════════════════════════════════════════════════════════════
# Development and Testing (optional)
# ════════════════════════════════════════════════════════════

# DEBUG=false
# LOG_LEVEL=INFO
